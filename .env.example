# Copia este archivo a .env y completa con tus credenciales de Khipu
# https://khipu.com/page/merchant
# Nunca subas .env al repositorio ni uses prefijo VITE_ en secretos.

KHIPU_RECEIVER_ID=
KHIPU_SECRET=
# URL pública donde Khipu envía POST al confirmar (ej. https://tudominio.cl/api/khipu/notify)
KHIPU_NOTIFY_URL=
APP_URL=http://localhost:5173
# En Vercel: pon la URL pública (https://tu-dominio.cl). Si falta, se usa VERCEL_URL del deploy.
KHIPU_API_PORT=3001
# Límites de monto por donación (CLP)
KHIPU_MIN_AMOUNT=1000
KHIPU_MAX_AMOUNT=5000000
# Orígenes extra para CORS en producción (separados por coma), además de APP_URL
# CORS_ALLOWED_ORIGINS=https://www.tudominio.cl

# Supabase — libro de transferencias en vivo (ejecuta supabase/migrations/001_donations.sql)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Solo lectura + Realtime en el navegador (Settings → API → anon public)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
