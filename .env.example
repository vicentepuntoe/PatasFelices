# Copia este archivo a .env y completa con tus credenciales de Khipu
# https://khipu.com/page/merchant
# Nunca subas .env al repositorio ni uses prefijo VITE_ en secretos.

KHIPU_RECEIVER_ID=
KHIPU_SECRET=
# Opcional: default https://khipu.com/api/2.0 (Chile). No uses payment-api.khipu.com/v2.
# KHIPU_API_BASE_URL=https://khipu.com/api/2.0
# URL pública donde Khipu envía POST al confirmar (ej. https://tudominio.cl/api/khipu/notify)
KHIPU_NOTIFY_URL=
APP_URL=http://localhost:5173
# En Vercel: https://tu-proyecto.vercel.app (misma URL en return_url y webhook)
KHIPU_API_PORT=3001
# Límites de monto por donación (CLP)
KHIPU_MIN_AMOUNT=1000
KHIPU_MAX_AMOUNT=100000
# Orígenes extra para CORS en producción (separados por coma), además de APP_URL
# CORS_ALLOWED_ORIGINS=https://www.tudominio.cl

# Supabase — libro de donaciones (migraciones en supabase/migrations/)
# Project URL → Settings → API
SUPABASE_URL=https://TU-REF.supabase.co
# Secret key (sb_secret_…) — solo servidor; alias: SUPABASE_SECRET_KEY
SUPABASE_SERVICE_ROLE_KEY=
# Misma URL que SUPABASE_URL
VITE_SUPABASE_URL=
# Publishable key (sb_publishable_…) en el build del front; alias: VITE_SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_ANON_KEY=
